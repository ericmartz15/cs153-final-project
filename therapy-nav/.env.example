# Set to true to run without an Anthropic API key (uses scripted mock responses)
# Flip to false (or remove) once you have API credits
MOCK_MODE=true

# Required when MOCK_MODE=false: your Anthropic API key
ANTHROPIC_API_KEY=sk-ant-...

# Backend port
PORT=3001

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Session TTL in milliseconds (default: 2 hours)
SESSION_TTL_MS=7200000

# Max profiles to extract from search
MAX_SEARCH_RESULTS=20

# Max profiles to show user in shortlist
MAX_SHORTLIST=5

# Run Playwright in headless mode (true in production)
PLAYWRIGHT_HEADLESS=true
